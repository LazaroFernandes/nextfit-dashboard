# Copie este arquivo para `.env` e preencha os valores reais

# --- API publica de integracao (documentada em /swagger) ---
NEXTFIT_API_KEY=
NEXTFIT_BASE_URL=https://integracao.nextfit.com.br
NEXTFIT_API_VERSION=1

# --- Google Sheets ---
# ID da planilha (pegue da URL: docs.google.com/spreadsheets/d/<ESTE_ID>/edit)
GOOGLE_SHEET_ID=
# Caminho do JSON da service account do Google Cloud
GOOGLE_CREDENTIALS_FILE=credentials/service-account.json

# --- API v2 interna (opcional, para puxar presencas/acessos/catraca/treinos) ---
# JWT Bearer extraido do DevTools do painel (api.nextfit.com.br).
# Expira em ~10h, mas renova automaticamente usando o refresh_token.
# Como pegar na primeira vez: https://app.nextfit.com.br -> F12 -> Console ->
#   localStorage.getItem("X-AUTH-TOKEN")  e  localStorage.getItem("X-REFRESH-TOKEN")
NEXTFIT_V2_TOKEN=
# Refresh token (validade ~5 dias) — usado pra renovar o access token sem captcha
NEXTFIT_V2_REFRESH_TOKEN=
# Codigo da unidade (aparece no painel ou no JWT como codigoUnidadePreferencial)
NEXTFIT_CODIGO_UNIDADE=
# Periodo das presencas. Escolha UM dos dois:
# (A) Data inicial fixa (formato YYYY-MM-DD). Se definida, tem prioridade.
NEXTFIT_PRESENCAS_DATA_INICIAL=
# (B) Quantos dias pra tras a partir de hoje (usado quando DATA_INICIAL esta vazio)
NEXTFIT_PRESENCAS_DIAS=30
