# Cópia este arquivo pra .streamlit/secrets.toml pra rodar local com st.secrets
# (opcional — se existir .env, o dashboard usa o .env como fallback)
#
# No Streamlit Community Cloud, cole o conteúdo deste arquivo no campo
# "Secrets" em app settings (NÃO commite o secrets.toml real).

# Planilha do sync NextFit (Clientes/Presencas/etc.) — usada para ler presencas reais
GOOGLE_SHEET_ID = "cole-o-id-da-planilha-de-sync-aqui"

# Planilha "Controle Professores" (Alunos/RegistroSemanal/Config) — usada pelo app_professor
CONTROLE_PROFESSORES_SHEET_ID = "cole-o-id-da-planilha-controle-aqui"

# Senha de acesso ao app_professor (deixe vazio/remova para acesso livre)
APP_PASSWORD = "defina-uma-senha-aqui"

[gcp_service_account]
# Cole o conteúdo do credentials/service-account.json campo a campo:
type = "service_account"
project_id = "seu-project-id"
private_key_id = "..."
private_key = """-----BEGIN PRIVATE KEY-----
...chave privada multi-linha...
-----END PRIVATE KEY-----
"""
client_email = "nome@projeto.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
universe_domain = "googleapis.com"
