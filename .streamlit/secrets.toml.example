# Cópia este arquivo pra .streamlit/secrets.toml pra rodar local com st.secrets
# (opcional — se existir .env, o dashboard usa o .env como fallback)
#
# No Streamlit Community Cloud, cole o conteúdo deste arquivo no campo
# "Secrets" em app settings (NÃO commite o secrets.toml real).

# Planilha do sync NextFit (Clientes/Presencas/etc.) — usada para ler presencas reais
GOOGLE_SHEET_ID = "cole-o-id-da-planilha-de-sync-aqui"

# Planilha "Controle Professores" (Alunos/RegistroSemanal/Config) — usada pelo app_professor
CONTROLE_PROFESSORES_SHEET_ID = "cole-o-id-da-planilha-controle-aqui"

# Senha-MESTRA opcional: quem entrar com ela escolhe qualquer professor (admin).
# Deixe vazio/remova se nao quiser senha-mestra.
APP_PASSWORD = "defina-uma-senha-mestra-aqui"

# Senha por professor: o nome (chave) tem que bater com a coluna "Professor" da
# aba Alunos. Quem entra com a senha de um professor ve so os alunos dele.
[senhas_professores]
"Lucas Eduardo Fiore" = "senha-do-lucas-fiore"
"Kevin Schuler" = "senha-do-kevin"
"Anderson Da Silva Santos" = "senha-do-anderson"
"Katiucy Lauser" = "senha-da-katiucy"
"Lucas Siqueira" = "senha-do-siqueira"
"Cristina Gabriela Frohlich" = "senha-da-cristina"
"Italo Vieira" = "senha-do-italo"
"Lazaro Fernandes" = "senha-do-lazaro"

[gcp_service_account]
# Cole o conteúdo do credentials/service-account.json campo a campo:
type = "service_account"
project_id = "seu-project-id"
private_key_id = "..."
private_key = """-----BEGIN PRIVATE KEY-----
...chave privada multi-linha...
-----END PRIVATE KEY-----
"""
client_email = "nome@projeto.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
universe_domain = "googleapis.com"
